//Define como se ven tablas, columnas y relaciones (plano)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      String   @default("guest")
  document  String?
  phone     String?
  bookings  Booking[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Room {
  id          Int      @id @default(autoincrement())
  number      Int      @unique
  type        String
  floor       Int
  price       Float
  capacity    Int
  description String
  status      String   @default("available")
  bookings    Booking[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("rooms")
}

model Booking {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  roomId     Int
  room       Room     @relation(fields: [roomId], references: [id])
  checkIn    DateTime
  checkOut   DateTime
  guests     Int
  totalPrice Float
  status     String   @default("pending")
  invoice    Invoice?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("bookings")
}

model Invoice {
  id         Int      @id @default(autoincrement())
  bookingId  Int      @unique
  booking    Booking  @relation(fields: [bookingId], references: [id])
  issueDate  DateTime @default(now())
  subtotal   Float
  tax        Float
  total      Float
  pdfUrl     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("invoices")
}